# ─── Firebase ────────────────────────────────────────────────────────────────
# All VITE_* variables are bundled into the client at build time.
# They are PUBLIC — never put secrets (private keys, admin SDK keys) here.
# These values come from Firebase Console → Project Settings → Your Apps → SDK config.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# The app degrades gracefully if this is missing (Eco Coach will be disabled).
VITE_GEMINI_API_KEY=your_gemini_api_key
